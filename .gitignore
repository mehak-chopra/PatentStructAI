# --------------------------
# Python
# --------------------------
venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# --------------------------
# Environment Variables
# --------------------------
.env

# --------------------------
# Patent Data (Generated)
# --------------------------
data/extracted_images/
data/cropped_structures/
data/temp/*.pdf

# Keep patent number lists
!data/temp/patent_numbers.txt

# --------------------------
# Machine Learning Models
# --------------------------
*.pt
*.pth
*.onnx
*.ckpt
yolov8n.pt

# --------------------------
# Annotation Workflow
# --------------------------

# V1 temporary folders
annotations/raw_pages/
annotations/chemistry_pages/
annotations/chemistry_raw_pages/
annotations/confirmed_chemistry_pages/
annotations/non_chemistry_pages/

# V2 temporary folders
annotations/chemistry_raw_pages_v2/
annotations/confirmed_chemistry_pages_v2/
annotations/rejected_pages_v2/

# Dataset versions (generated)
annotations/datasets/v2/

# Annotation archives
annotations/raw_pages.zip
annotations/chemistry_raw_pages.zip
annotations/confirmed_chemistry_pages.zip
annotations/chemistry_raw_pages_v2.zip
annotations/confirmed_chemistry_pages_v2.zip

# --------------------------
# Experiment Tracking
# --------------------------
runs/
wandb/
predictions/
*.cache
events.out.tfevents*

