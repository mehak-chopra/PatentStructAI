# --------------------------
# Python
# --------------------------
venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# --------------------------
# Environment Variables
# --------------------------
.env

# --------------------------
# Patent Data (Generated)
# --------------------------
data/extracted_images/
data/cropped_structures/
data/temp/*.pdf

# Keep patent_numbers.txt
!data/temp/patent_numbers.txt

# --------------------------
# Machine Learning Models
# --------------------------
*.pt
*.pth
*.onnx
*.ckpt

# --------------------------
# Annotation / Training Data
# --------------------------

# Annotation workflow folders
annotations/raw_pages/
annotations/chemistry_pages/
annotations/chemistry_raw_pages/
annotations/confirmed_chemistry_pages/
annotations/non_chemistry_pages/

# Annotation zip archives
annotations/raw_pages.zip
annotations/chemistry_raw_pages.zip
annotations/confirmed_chemistry_pages.zip

# Experiment tracking
runs/
wandb/

# YOLO cache files
*.cache

# --------------------------
# Jupyter
# --------------------------
.ipynb_checkpoints/

# --------------------------
# IDE
# --------------------------
.vscode/

# --------------------------
# Logs
# --------------------------
*.log

# --------------------------
# Database Files
# --------------------------
*.db
*.sqlite
*.sqlite3

# --------------------------
# Operating System Files
# --------------------------
.DS_Store
Thumbs.db

# --------------------------
# Exported datasets
# --------------------------
*.zip

# --------------------------
# TensorBoard
# --------------------------
events.out.tfevents*

# --------------------------
# Ultralytics / YOLO
# --------------------------
runs/
*.cache

# Prediction outputs
predictions/